import os
import requests

UNITYSVC_API_KEY = os.environ.get("UNITYSVC_API_KEY")

def generate_embedding(text, model="{{offering.name}}"):
    url = "https://api.tokenfactory.nebius.com/v1/embeddings"

    payload = {
        "model": model,
        "input": text
    }

    headers = {
        "Authorization": f"Bearer {UNITYSVC_API_KEY}",
        "Content-Type": "application/json",
        "Accept": "*/*"
    }

    response = requests.post(url, json=payload, headers=headers)

    if not response.ok:
        raise Exception(f"HTTP {response.status_code}: {response.text}")

    return response.json()


# Example
if __name__ == "__main__":
    out = generate_embedding("saturday")
    print(out)
