import os
import requests
import base64

UNITYSVC_API_KEY = os.environ.get("UNITYSVC_API_KEY")

url = "https://api.studio.nebius.ai/v1/images/generations"

payload = {
    "model": "{{offering.name}}",
    "prompt": "a futuristic city at sunrise, ultra detailed",
    "size": "1024x1024"
}

headers = {
    "Authorization": f"Bearer {UNITYSVC_API_KEY}",
    "Content-Type": "application/json"
}

res = requests.post(url, headers=headers, json=payload)

print("Status:", res.status_code)
data = res.json()
print(data)

# Handle both possible formats: b64_json or url
if "data" in data and len(data["data"]) > 0:
    item = data["data"][0]

    if "b64_json" in item and item["b64_json"]:
        # Base64 case
        img_bytes = base64.b64decode(item["b64_json"])
        with open("flux_output.png", "wb") as f:
            f.write(img_bytes)
        print("Saved → flux_output.png")

    elif "url" in item and item["url"]:
        # URL case
        img_url = item["url"]
        img_res = requests.get(img_url)

        with open("flux_output.png", "wb") as f:
            f.write(img_res.content)

        print("Saved image from URL → flux_output.png")

    else:
        print("Model returned no usable image data.")
else:
    print("No image data returned.")
